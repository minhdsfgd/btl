<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500" prefWidth="800" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.code.controllers.SellerDashboardController">

    <VBox prefHeight="500" prefWidth="800" style="-fx-background-color: #003b22;">


        <HBox alignment="CENTER_LEFT" style="-fx-background-color:#065f3b; -fx-padding:10;">
            <Label style="-fx-text-fill:white; -fx-font-size:16; -fx-font-weight:bold;" text="DANH SÁCH PHIÊN" />

            <Region HBox.hgrow="ALWAYS" />

            <Label style="-fx-text-fill:#c8f5e1; -fx-padding: 0 10 0 0;" text="username" />

            <!-- Nút Đăng xuất đã đổi sang nền đỏ -->
            <Button style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 5 15;" text="Đăng xuất">
            <font>
               <Font size="12.0" />
            </font></Button>
        </HBox>


        <HBox spacing="10" style="-fx-padding:10;">
            <TextField promptText="Tìm kiếm theo tên sản phẩm..." style="-fx-background-radius:8; -fx-padding:8;" HBox.hgrow="ALWAYS" />

            <Button style="-fx-background-color:#16a34a; -fx-text-fill:white; -fx-background-radius:8;" text="🔍" />
        </HBox>


        <HBox spacing="10" style="-fx-padding:0 10 10 10;">
            <Button styleClass="filter-active" text="Tất cả" />
            <Button styleClass="filter" text="Đang diễn ra" />
            <Button styleClass="filter" text="Sắp mở" />
            <Button styleClass="filter" text="Kết thúc" />
        </HBox>


        <VBox spacing="10" style="-fx-padding:10;" VBox.vgrow="ALWAYS">

            <HBox styleClass="card">


                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill:white; -fx-font-size:14; -fx-font-weight:bold;" text="Tên sản phẩm" />

                    <Label style="-fx-text-fill:#9fe6c8;" text="Loại sản phẩm" />

                    <Label style="-fx-text-fill:#22c55e;" text="Giá hiện tại" />

                    <Label style="-fx-text-fill:#9fe6c8;" text="⏱ Thời gian còn lại" />
                </VBox>


                <VBox alignment="CENTER_RIGHT" spacing="10">

                    <Label style="-fx-background-color:#d1fae5; -fx-text-fill:#065f3b; -fx-padding:4 10; -fx-background-radius:20;" text="Trạng thái" />

                    <Button style="-fx-background-color:#16a34a; -fx-text-fill:white; -fx-background-radius:8;" text="Hành động" />
                </VBox>

            </HBox>

        </VBox>

    </VBox>

</AnchorPane>
