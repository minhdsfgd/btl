<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="520" prefWidth="880" style="-fx-background-color: #012b18;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.code.controllers.LiveBiddingController">

    <VBox spacing="0">

        <!-- HEADER -->
        <HBox alignment="CENTER" prefHeight="55" style="-fx-background-color: #011f12; -fx-padding: 0 25;">

            <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #4caf50; -fx-font-size: 18; -fx-font-weight: bold;" text="AUCTION SYSTEM">
               <font>
                  <Font name="Segoe UI Bold" size="14.0" />
               </font></Label>
                <Label style="-fx-text-fill: #6a8a75; -fx-font-size: 10;" text="ĐẤU GIÁ TRỰC TIẾP" />
            </VBox>

            <Label fx:id="currentUserLabel" style="-fx-text-fill: #cccccc; -fx-font-size: 11;" />
        </HBox>

        <!-- MAIN -->
        <HBox spacing="16" style="-fx-padding: 16;" VBox.vgrow="ALWAYS">

            <!-- LEFT -->
            <VBox prefWidth="410" spacing="12">

                <!-- PRODUCT -->
                <VBox spacing="8" style="-fx-background-color: #0f3d2a;                              -fx-background-radius: 8;                              -fx-padding: 12;">
                    <Label style="-fx-text-fill: #7fae94; -fx-font-size: 10;" text="SẢN PHẨM" />
                    <HBox spacing="8">
                        <ImageView fx:id="productImageView" fitHeight="60" fitWidth="60" />
                        <VBox spacing="3">
                            <Label fx:id="productNameLabel" style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
                            <Label fx:id="productDescLabel" style="-fx-text-fill: #9bbfa8; -fx-font-size: 10;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- PRICE -->
                <VBox prefHeight="68.0" prefWidth="410.0" spacing="6" style="-fx-background-color: #0f3d2a;                              -fx-background-radius: 8;                              -fx-padding: 12;">
                    <Label style="-fx-text-fill: #7fae94; -fx-font-size: 10;" text="GIÁ HIỆN TẠI" />
                    <Label fx:id="currentPriceLabel" style="-fx-text-fill: #4caf50; -fx-font-size: 22; -fx-font-weight: bold;" />
                    <Label fx:id="leadingBidderLabel" style="-fx-text-fill: white; -fx-font-size: 11;" />
                </VBox>

                <!-- TIME -->
                <VBox spacing="6" style="-fx-background-color: #0f3d2a;                              -fx-background-radius: 8;                              -fx-padding: 12;">
                    <Label style="-fx-text-fill: #7fae94; -fx-font-size: 10;" text="THỜI GIAN" />
                    <Label fx:id="countdownLabel" style="-fx-text-fill: #4dd0e1; -fx-font-size: 26; -fx-font-weight: bold;" text="--:--:--" />
                </VBox>

            </VBox>

            <!-- RIGHT -->
            <VBox prefWidth="410" spacing="12">

                <!-- BID (CENTERED + SMALL) -->
                <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #0f3d2a;                              -fx-background-radius: 8;                              -fx-padding: 14;">

                    <Label style="-fx-text-fill: #7fae94; -fx-font-size: 10;" text="ĐẶT GIÁ" />

                    <TextField fx:id="bidAmountField" maxWidth="274.0" onAction="#handlePlaceBid" prefHeight="31.0" prefWidth="274.0" promptText=" Nhập giá (VND)" style="-fx-background-color: #012b18;                                       -fx-text-fill: white;                                       -fx-border-color: #1e5e38;                                       -fx-font-size: 14;                                       -fx-alignment: CENTER;" />

                    <Label fx:id="errorLabel" style="-fx-text-fill: #ef5350; -fx-font-size: 10;" />

                    <Button onAction="#handlePlaceBid" prefWidth="180" style="-fx-background-color: #2e7d32;                                    -fx-text-fill: white;                                    -fx-font-size: 13;                                    -fx-font-weight: bold;" text="ĐẶT GIÁ" />
                </VBox>

                <!-- HISTORY -->
                <VBox spacing="8" style="-fx-background-color: #0f3d2a;                              -fx-background-radius: 8;                              -fx-padding: 12;">
                    <Label style="-fx-text-fill: #7fae94; -fx-font-size: 10;" text="LỊCH SỬ" />

                    <TableView fx:id="bidHistoryTable" prefHeight="200" style="-fx-background-color: #0f3d2a;                                       -fx-control-inner-background: #0f3d2a;                                       -fx-table-cell-border-color: #1e5e38;">

                        <columns>
                            <TableColumn fx:id="colUsername" prefWidth="120" text="User" />
                            <TableColumn fx:id="colTime" prefWidth="110" text="Time" />
                            <TableColumn fx:id="colAmount" prefWidth="140" text="Price" />
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

        </HBox>

        <!-- EXIT BUTTON -->
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 20 15 20;">
            <Button onAction="#handleExitRoom" style="-fx-background-color: #c62828;                            -fx-text-fill: white;                            -fx-font-size: 11;                            -fx-padding: 6 14;                            -fx-background-radius: 6;" text="Thoát phòng" />
        </HBox>

    </VBox>
</StackPane>
