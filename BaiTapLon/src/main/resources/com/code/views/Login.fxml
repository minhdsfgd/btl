<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefWidth="800" prefHeight="500"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.code.controllers.SellerDashboardController">

   <HBox prefWidth="800" prefHeight="500">

      <!-- SIDEBAR -->
      <VBox prefWidth="150" style="-fx-background-color: #013220;">
         <padding>
            <Insets top="15" left="10"/>
         </padding>

         <Label text="AUCTION"
                style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;"/>

         <VBox spacing="10" style="-fx-padding: 20 0;">
            <Button text="Tổng quan"/>
            <Button text="Quản lý lô"/>
            <Button text="Phiên đấu"/>
         </VBox>

         <Region VBox.vgrow="ALWAYS"/>
         <Button text="Đăng xuất"/>
      </VBox>

      <!-- MAIN -->
      <VBox spacing="12" style="-fx-background-color: #012b18; -fx-padding: 12;"
            HBox.hgrow="ALWAYS">

         <!-- HEADER -->
         <Label text="Seller Dashboard"
                style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>

         <!-- STATS -->
         <GridPane hgap="10" vgap="10">

            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS"/>
               <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- row 1 -->
            <VBox GridPane.rowIndex="0" GridPane.columnIndex="0"
                  style="-fx-background-color:#014d33; -fx-padding:10; -fx-background-radius:8;">
               <Label text="Tổng lô" style="-fx-text-fill:white;"/>
               <TextField fx:id="totalField" editable="false"/>
            </VBox>

            <VBox GridPane.rowIndex="0" GridPane.columnIndex="1"
                  style="-fx-background-color:#014d33; -fx-padding:10; -fx-background-radius:8;">
               <Label text="Đang đấu" style="-fx-text-fill:white;"/>
               <TextField fx:id="activeField" editable="false"/>
            </VBox>

            <!-- row 2 -->
            <VBox GridPane.rowIndex="1" GridPane.columnIndex="0"
                  style="-fx-background-color:#014d33; -fx-padding:10; -fx-background-radius:8;">
               <Label text="Sắp diễn ra" style="-fx-text-fill:white;"/>
               <TextField fx:id="upcomingField" editable="false"/>
            </VBox>

            <VBox GridPane.rowIndex="1" GridPane.columnIndex="1"
                  style="-fx-background-color:#014d33; -fx-padding:10; -fx-background-radius:8;">
               <Label text="Đã bán" style="-fx-text-fill:white;"/>
               <TextField fx:id="soldField" editable="false"/>
            </VBox>

         </GridPane>

         <!-- TABLE -->
         <VBox spacing="6" style="-fx-background-color:#014d33; -fx-padding:10; -fx-background-radius:8;"
               VBox.vgrow="ALWAYS">

            <HBox>
               <Label text="Danh sách lô" style="-fx-text-fill:white;"/>
               <Region HBox.hgrow="ALWAYS"/>
               <Button text="+ Thêm"/>
            </HBox>

            <!-- header -->
            <HBox spacing="5">
               <Label text="Mã" prefWidth="100" style="-fx-text-fill:#9fe6c8;"/>
               <Label text="Tên" prefWidth="150" style="-fx-text-fill:#9fe6c8;"/>
               <Label text="Giá" prefWidth="100" style="-fx-text-fill:#9fe6c8;"/>
               <Label text="Trạng thái" prefWidth="120" style="-fx-text-fill:#9fe6c8;"/>
            </HBox>

            <!-- row -->
            <HBox spacing="5">
               <TextField prefWidth="100" editable="false"/>
               <TextField prefWidth="150" editable="false"/>
               <TextField prefWidth="100" editable="false"/>
               <TextField prefWidth="120" editable="false"/>
            </HBox>

            <HBox spacing="5">
               <TextField prefWidth="100" editable="false"/>
               <TextField prefWidth="150" editable="false"/>
               <TextField prefWidth="100" editable="false"/>
               <TextField prefWidth="120" editable="false"/>
            </HBox>

         </VBox>

         <!-- FOOT -->
         <HBox spacing="10">

            <VBox style="-fx-background-color:#014d33; -fx-padding:10; -fx-background-radius:8;"
                  HBox.hgrow="ALWAYS">
               <Label text="Doanh thu" style="-fx-text-fill:white;"/>
               <Pane prefHeight="80" style="-fx-border-color:#3a7f6b;"/>
            </VBox>

            <VBox style="-fx-background-color:#014d33; -fx-padding:10; -fx-background-radius:8;"
                  HBox.hgrow="ALWAYS">
               <Label text="Hoạt động" style="-fx-text-fill:white;"/>
               <TextField editable="false"/>
            </VBox>

         </HBox>

      </VBox>
   </HBox>
</AnchorPane>