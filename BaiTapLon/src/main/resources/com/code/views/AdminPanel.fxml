<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>



<StackPane prefHeight="500" prefWidth="800" style="-fx-background-color: #012b18;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.code.controllers.AdminPanelController">

    <VBox spacing="0">


        <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="10" style="-fx-background-color: #011f12;                  -fx-padding: 0 20 0 20;">
            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #4caf50;                       -fx-font-size: 15;                       -fx-font-weight: bold;" text="ADMIN PANEL">
               <font>
                  <Font name="Segoe UI Bold" size="14.0" />
               </font></Label>
            </VBox>

            <Label fx:id="lblAdminName" style="-fx-text-fill: #cccccc;                     -fx-font-size: 11;" />
            <Button onAction="#handleLogout" prefHeight="18.0" prefWidth="85.0" style="-fx-background-color: transparent;                      -fx-text-fill: white;                      -fx-border-color: rgba(255,255,255,0.4);                      -fx-border-radius: 6; -fx-background-radius: 6;                      -fx-font-size: 11; -fx-cursor: hand;                      -fx-padding: 4 12 4 12;" text="Đăng xuất" />
        </HBox>


        <HBox spacing="10" style="-fx-padding: 10 18 6 18;">


            <VBox alignment="CENTER" spacing="3" style="-fx-background-color: #0f3d2a;                    -fx-background-radius: 7;                    -fx-padding: 8 10 8 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7fae94; -fx-font-size: 9;" text="TỔNG NGƯỜI DÙNG" />
                <Label fx:id="lblTotalUsers" style="-fx-text-fill: white;                       -fx-font-size: 20; -fx-font-weight: bold;" />
            </VBox>


            <VBox alignment="CENTER" spacing="3" style="-fx-background-color: #0f3d2a;                    -fx-background-radius: 7;                    -fx-padding: 8 10 8 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7fae94; -fx-font-size: 9;" text="PHIÊN ĐANG MỞ" />
                <Label fx:id="lblActiveSessions" style="-fx-text-fill: #4caf50;                       -fx-font-size: 20; -fx-font-weight: bold;" />
            </VBox>


            <VBox alignment="CENTER" spacing="3" style="-fx-background-color: #0f3d2a;                    -fx-background-radius: 7;                    -fx-padding: 8 10 8 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7fae94; -fx-font-size: 9;" text="TỔNG PHIÊN" />
                <Label fx:id="lblTotalSessions" style="-fx-text-fill: white;                       -fx-font-size: 20; -fx-font-weight: bold;" />
            </VBox>


            <VBox alignment="CENTER" spacing="3" style="-fx-background-color: #0f3d2a;                    -fx-background-radius: 7;                    -fx-padding: 8 10 8 10;" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7fae94; -fx-font-size: 9;" text="DOANH THU" />
                <Label fx:id="lblRevenue" style="-fx-text-fill: #4dd0e1;                       -fx-font-size: 20; -fx-font-weight: bold;" />
            </VBox>

        </HBox>


        <HBox spacing="8" style="-fx-padding: 6 18 6 18;">

            <Button fx:id="tabBtnUsers" maxWidth="Infinity" onAction="#switchToUsers" style="-fx-background-color: #16a34a;                      -fx-text-fill: white;                      -fx-font-size: 13; -fx-font-weight: bold;                      -fx-background-radius: 7;                      -fx-cursor: hand; -fx-padding: 7 0 7 0;" text="Quản lý người dùng" HBox.hgrow="ALWAYS" />
            <Button fx:id="tabBtnSessions" maxWidth="Infinity" onAction="#switchToSessions" style="-fx-background-color: transparent;                      -fx-text-fill: rgba(255,255,255,0.5);                      -fx-border-color: rgba(255,255,255,0.2);                      -fx-border-radius: 7; -fx-background-radius: 7;                      -fx-font-size: 13;                      -fx-cursor: hand; -fx-padding: 7 0 7 0;" text="Quản lý phiên đấu giá" HBox.hgrow="ALWAYS" />
        </HBox>


        <StackPane style="-fx-padding: 0 18 12 18;" VBox.vgrow="ALWAYS">


            <VBox fx:id="panelUsers" spacing="8" style="-fx-background-color: #0f3d2a;                    -fx-background-radius: 8;                    -fx-padding: 10 12 10 12;">


                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-text-fill: #7fae94; -fx-font-size: 9;" text="DANH SÁCH NGƯỜI DÙNG" HBox.hgrow="ALWAYS" />

                    <TextField fx:id="tfUserSearch" onKeyReleased="#handleUserSearch" prefWidth="160" promptText="Tìm theo tên / email..." style="-fx-background-color: white;                             -fx-text-fill: #1a1a1a;                             -fx-prompt-text-fill: #999;                             -fx-border-radius: 5; -fx-background-radius: 5;                             -fx-padding: 4 8 4 8; -fx-font-size: 11;" />

                    <ComboBox fx:id="cmbRoleFilter" onAction="#handleUserSearch" prefWidth="120" style="-fx-background-color: #e8e8e8;                            -fx-background-radius: 5;                            -fx-font-size: 11;" />
                    <Button onAction="#handleAddUser" style="-fx-background-color: #2e7d32;                          -fx-text-fill: white;                          -fx-background-radius: 5;                          -fx-font-size: 11; -fx-cursor: hand;                          -fx-padding: 5 10 5 10;" text="+ Thêm người dùng" />
                </HBox>


                <TableView fx:id="tableUsers" style="-fx-background-color: #0f3d2a;                           -fx-control-inner-background: #0f3d2a;                           -fx-table-cell-border-color: #1e5e38;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colUserId" prefWidth="38" text="ID" />
                        <TableColumn fx:id="colUserName" prefWidth="130" text="Họ tên" />
                        <TableColumn fx:id="colUserEmail" prefWidth="160" text="Email" />
                        <TableColumn fx:id="colUserRole" prefWidth="70" text="Vai trò" />
                        <TableColumn fx:id="colUserStatus" prefWidth="80" text="Trạng thái" />
                        <TableColumn fx:id="colUserAction" prefWidth="100" text="Hành động" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #4a7a5e; -fx-font-size: 11;" text="Chưa có dữ liệu — gọi ctrl.setUsers()" />
                    </placeholder>
                </TableView>

                <Label fx:id="lblUserMsg" style="-fx-text-fill: #ef5350; -fx-font-size: 10;" />
            </VBox>

            <VBox fx:id="panelSessions" managed="false" spacing="8" style="-fx-background-color: #0f3d2a;                    -fx-background-radius: 8;                    -fx-padding: 10 12 10 12;" visible="false">


                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-text-fill: #7fae94; -fx-font-size: 9;" text="DANH SÁCH PHIÊN ĐẤU GIÁ" HBox.hgrow="ALWAYS" />

                    <TextField fx:id="tfSessionSearch" onKeyReleased="#handleSessionSearch" prefWidth="160" promptText="Tìm theo sản phẩm..." style="-fx-background-color: white;                             -fx-text-fill: #1a1a1a;                             -fx-prompt-text-fill: #999;                             -fx-border-radius: 5; -fx-background-radius: 5;                             -fx-padding: 4 8 4 8; -fx-font-size: 11;" />
                    <
                    <ComboBox fx:id="cmbStatusFilter" onAction="#handleSessionSearch" prefWidth="120" style="-fx-background-color: #e8e8e8;                            -fx-background-radius: 5;                            -fx-font-size: 11;" />
                    <Button onAction="#handleCreateSession" style="-fx-background-color: #2e7d32;                          -fx-text-fill: white;                          -fx-background-radius: 5;                          -fx-font-size: 11; -fx-cursor: hand;                          -fx-padding: 5 10 5 10;" text="+ Tạo phiên" />
                </HBox>


                <TableView fx:id="tableSessions" style="-fx-background-color: #0f3d2a;                           -fx-control-inner-background: #0f3d2a;                           -fx-table-cell-border-color: #1e5e38;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSessionId" prefWidth="38" text="ID" />
                        <TableColumn fx:id="colSessionProduct" prefWidth="160" text="Sản phẩm" />
                        <TableColumn fx:id="colSessionStartPrice" prefWidth="110" text="Giá khởi điểm" />
                        <TableColumn fx:id="colSessionCurPrice" prefWidth="110" text="Giá hiện tại" />
                        <TableColumn fx:id="colSessionStatus" prefWidth="80" text="Trạng thái" />
                        <TableColumn fx:id="colSessionAction" prefWidth="100" text="Hành động" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #4a7a5e; -fx-font-size: 11;" text="Chưa có dữ liệu — gọi ctrl.setSessions()" />
                    </placeholder>
                </TableView>

                <Label fx:id="lblSessionMsg" style="-fx-text-fill: #ef5350; -fx-font-size: 10;" />
            </VBox>

        </StackPane>
    </VBox>
</StackPane>
